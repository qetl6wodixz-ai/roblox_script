-- Teleport helper function
local function teleportTo(part)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp and part and part:IsA("BasePart") then
        hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)
    end
end

-- Autofarm function
local function runAutofarm()
    local rooms = workspace:FindFirstChild("Rooms")
    if not rooms then return end
    
    local list = rooms:GetChildren()
    table.sort(list, function(a, b) return tonumber(a.Name) < tonumber(b.Name) end)
    local idx = #list - 1
    
    if idx >= 1 then
        local room = list[idx]
        local target = room:FindFirstChild("Entrance") or room:FindFirstChildWhichIsA("BasePart")
        if target then 
            teleportTo(target)
        end
    end
end

local function startAutofarm()
    if farmConnection then farmConnection:Disconnect() end
    
    farmConnection = task.spawn(function()
        while farming do
            pcall(runAutofarm)
            task.wait(0.1)
        end
    end)
end

local function stopAutofarm()
    if farmConnection then
        task.cancel(farmConnection)
        farmConnection = nil
    end
end

-- AutoMod function
local function runAutoMod()
    local rooms = workspace:FindFirstChild("Rooms")
    if not rooms then return end
    
    local saferoom = rooms:FindFirstChild("Saferoom") or rooms:FindFirstChild("SafeRoom")
    
    if saferoom then
        local target = saferoom:FindFirstChild("Entrance") or saferoom:FindFirstChildWhichIsA("BasePart")
