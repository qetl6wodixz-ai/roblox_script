-- IMPROVED Notification system with timer bar (Bottom Right)
local function updateNotificationPositions()
    for i, notification in ipairs(activeNotifications) do
        local newPosition = UDim2.new(1, -260, 1, -(i * (notificationHeight + notificationSpacing) + 10))
        -- NO TWEEN - Direct position change
        notification.Position = newPosition
    end
end

local function showNotification(text)
    local notif = Instance.new("Frame", ScreenGui)
    notif.Size = UDim2.new(0, 250, 0, notificationHeight)
    notif.Position = UDim2.new(1, -260, 1, -notificationHeight - 10)
    notif.BackgroundColor3 = THEME.bg
    notif.BorderSizePixel = 0
    
    local corner = Instance.new("UICorner", notif)
    corner.CornerRadius = UDim.new(0, 8)
    
    local outline = Instance.new("UIStroke", notif)
    outline.Color = THEME.outline
    outline.Thickness = 2
    
    local label = Instance.new("TextLabel", notif)
    label.Size = UDim2.new(1, -10, 1, -5)
    label.Position = UDim2.new(0, 5, 0, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Code
    label.Text = text
    label.TextColor3 = THEME.text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.TextWrapped = true
    
    -- Timer bar
    local timerBar = Instance.new("Frame", notif)
    timerBar.Size = UDim2.new(1, 0, 0, 3)
    timerBar.Position = UDim2.new(0, 0, 1, -3)
    timerBar.BackgroundColor3 = THEME.main
    timerBar.BorderSizePixel = 0
    
    local timerCorner = Instance.new("UICorner", timerBar)
    timerCorner.CornerRadius = UDim.new(0, 2)
    
    -- Add to active notifications at the beginning (top)
    table.insert(activeNotifications, 1, notif)
    updateNotificationPositions()
    
    -- Animate timer bar
    task.spawn(function()
        local startTime = tick()
        while notif.Parent and (tick() - startTime) < notificationDuration do
            local elapsed = tick() - startTime
            local progress = 1 - (elapsed / notificationDuration)
            timerBar.Size = UDim2.new(progress, 0, 0, 3)
            task.wait()
        end
        
        -- Remove from active notifications
        for i, activeNotif in ipairs(activeNotifications) do
            if activeNotif == notif then
                table.remove(activeNotifications, i)
                break
            end
        end
        
        notif:Destroy()
        updateNotificationPositions() -- Update positions without animation
    end)
end

