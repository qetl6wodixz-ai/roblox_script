-- Beacons function
local function runBeacons()
    local beaconModel = workspace:FindFirstChild("Beacons")
    if not beaconModel then return end
    
    local parts = {}
    for _, part in ipairs(beaconModel:GetDescendants()) do
        if part:IsA("BasePart") and part.Name == "Part" then
            table.insert(parts, part)
        end
    end
    
    if #parts > 0 then
        teleportTo(parts[math.random(1, #parts)])
    end
end

local function startBeacons()
    if beaconConnection then beaconConnection:Disconnect() end
    
    beaconConnection = task.spawn(function()
        while beaconsOn do
            pcall(runBeacons)
            task.wait(0.1)
        end
    end)
end

local function stopBeacons()
    if beaconConnection then
        task.cancel(beaconConnection)
        beaconConnection = nil
    end
end

-- Functions for other features
local function saveNoClipState()
    originalCanCollide = {}
    if player.Character then
        for _, part in ipairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                originalCanCollide[part] = part.CanCollide
            end
        end
    end
end

local function restoreNoClipState()
    if player.Character then
        for part, canCollide in pairs(originalCanCollide) do
            if part and part.Parent then
                part.CanCollide = canCollide
            end
        end
    end
    originalCanCollide = {}
end

local function setPlayerScale(scale)
    if player.Character then
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid then
            for _, part in pairs(player.Character:GetChildren()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    local mesh = part:FindFirstChildOfClass("SpecialMesh")
                    if mesh then
                        mesh.Scale = Vector3.new(scale, scale, scale)
                    else
                        part.Size = part.Size * (scale / playerScale)
                    end
                end
            end
            
            for _, accessory in pairs(player.Character:GetChildren()) do
                if accessory:IsA("Accessory") then
                    local handle = accessory:FindFirstChild("Handle")
                    if handle then
                        local mesh = handle:FindFirstChildOfClass("SpecialMesh")
                        if mesh then
                            mesh.Scale = Vector3.new(scale, scale, scale)
                        end
                    end
                end
            end
            
            playerScale = scale
            
            if scaleSlider then
                scaleSlider.updateValue(scale)
            end
        end
    end
end

