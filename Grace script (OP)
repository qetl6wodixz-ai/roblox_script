-- Flashback system
local function startRecordingPositions()
    recordingPositions = true
    flashbackPositions = {}
    showNotification("Started recording positions for flashback")
end

local function stopRecordingPositions()
    recordingPositions = false
    showNotification("Stopped recording - " .. #flashbackPositions .. " positions saved")
end

local function executeFlashback()
    if #flashbackPositions == 0 then
        showNotification("No positions recorded for flashback")
        return
    end
    
    showNotification("Executing flashback with " .. #flashbackPositions .. " positions...")
    
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        showNotification("Character not found")
        return
    end
    
    task.spawn(function()
        for i = #flashbackPositions, 1, -1 do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                player.Character.HumanoidRootPart.CFrame = flashbackPositions[i]
                task.wait(0.03)
            else
                break
            end
        end
        showNotification("Flashback completed!")
    end)
end

-- IMPROVED Item giver function
local function giveItemById(itemId)
    if not itemId or itemId == "" then 
        showNotification("Please enter a valid item ID")
        return 
    end
    
    local id = tonumber(itemId)
    if not id then
        showNotification("Invalid ID format")
        return
    end
    
    local success = pcall(function()
        local itemRemote = ReplicatedStorage:FindFirstChild("GiveItem") or 
                          ReplicatedStorage:FindFirstChild("SpawnItem") or
                          ReplicatedStorage:FindFirstChild("AddItem")
        
        if itemRemote and itemRemote:IsA("RemoteEvent") then
            itemRemote:FireServer(id)
            showNotification("Item requested: " .. id)
            return
        end
        
        for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
            if obj:IsA("Tool") and obj.Name:find(tostring(id)) then
                local clonedTool = obj:Clone()
                clonedTool.Parent = player.Backpack
                showNotification("Given: " .. clonedTool.Name)
                return
            end
        end
        
        local productInfo = MarketplaceService:GetProductInfo(id)
        if productInfo then
            local tool = Instance.new("Tool")
            tool.Name = productInfo.Name or ("Item_" .. itemId)
            tool.RequiresHandle = true
            
            local handle = Instance.new("Part")
            handle.Name = "Handle"
            handle.Size = Vector3.new(1, 1, 1)
            handle.Material = Enum.Material.Plastic
            handle.BrickColor = BrickColor.new("Bright blue")
            handle.Shape = Enum.PartType.Block
            handle.TopSurface = Enum.SurfaceType.Smooth
            handle.BottomSurface = Enum.SurfaceType.Smooth
            handle.CanCollide = false
            handle.Parent = tool
            
            local mesh = Instance.new("SpecialMesh")
            mesh.MeshType = Enum.MeshType.FileMesh
            mesh.MeshId = "rbxassetid://" .. itemId
            mesh.TextureId = "rbxassetid://" .. itemId
            mesh.Scale = Vector3.new(1, 1, 1)
            mesh.Parent = handle
            
            local function onActivated()
                showNotification("Used: " .. tool.Name)
            end
            
            tool.Activated:Connect(onActivated)
            tool.Parent = player.Backpack
            
            showNotification("Given: " .. tool.Name)
        else
            showNotification("Item not found")
        end
    end)
    
    if not success then
        showNotification("Error creating item")
    end
end

