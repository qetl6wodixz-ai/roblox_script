local function getCurrentRoom()
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local rooms = workspace:FindFirstChild("Rooms")
        if rooms then
            local pos = player.Character.HumanoidRootPart.Position
            local closest = 0
            local minDist = math.huge
            
            for _, room in ipairs(rooms:GetChildren()) do
                local roomNum = tonumber(room.Name)
                if roomNum then
                    local roomParts = room:GetDescendants()
                    for _, part in ipairs(roomParts) do
                        if part:IsA("BasePart") then
                            local dist = (part.Position - pos).Magnitude
                            if dist < minDist then
                                minDist = dist
                                closest = roomNum
                            end
                        end
                    end
                end
            end
            return closest
        end
    end
    return 0
end

local function updateESP()
    for _, highlight in ipairs(espHighlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    espHighlights = {}
    
    local rooms = workspace:FindFirstChild("Rooms")
    if not rooms then return end
    
    for _, room in ipairs(rooms:GetChildren()) do
        if tonumber(room.Name) then
            local elkman = room:FindFirstChild("elkman", true)
            if elkman and elkman:IsA("Model") then
                local highlight = Instance.new("Highlight")
                highlight.Adornee = elkman
                highlight.FillColor = espColor
                highlight.FillTransparency = espTransparency
                highlight.OutlineColor = espColor:lerp(Color3.new(0, 0, 0), 0.3)
                highlight.Parent = elkman
                table.insert(espHighlights, highlight)
            end
            
            local door = room:FindFirstChild("Door", true)
            if door and door:IsA("Model") then
                local highlight = Instance.new("Highlight")
                highlight.Adornee = door
                highlight.FillColor = espColor
                highlight.FillTransparency = espTransparency
                highlight.OutlineColor = espColor:lerp(Color3.new(0, 0, 0), 0.3)
                highlight.Parent = door
                table.insert(espHighlights, highlight)
            end
        end
    end
end

local function updatePlayerESP()
    for _, highlight in ipairs(playerEspHighlights) do
        if highlight and highlight.Parent then
            highlight:Destroy()
        end
    end
    playerEspHighlights = {}
    
    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            local character = otherPlayer.Character
            local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
            
            if humanoidRootPart then
                local highlight = Instance.new("Highlight")
                highlight.Adornee = character
                highlight.FillColor = Color3.fromRGB(255, 100, 100)
                highlight.FillTransparency = 0.3
                highlight.OutlineColor = Color3.fromRGB(200, 0, 0)
                highlight.Parent = character
                table.insert(playerEspHighlights, highlight)
                
                local nameTag = Instance.new("BillboardGui", humanoidRootPart)
                nameTag.Name = "PlayerNameTag"
                nameTag.Size = UDim2.new(0, 100, 0, 50)
                nameTag.StudsOffset = Vector3.new(0, 3, 0)
                
                local nameLabel = Instance.new("TextLabel", nameTag)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Size = UDim2.new(1, 0, 1, 0)
                nameLabel.Font = Enum.Font.Code
                nameLabel.Text = otherPlayer.Name
                nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                nameLabel.TextSize = 14
                nameLabel.TextStrokeTransparency = 0
                nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                
                table.insert(playerEspHighlights, nameTag)
            end
        end
    end
end

local function updatePlayerStats()
    if not notifyOn then return end
    
    currentRoom = getCurrentRoom()
    roomLabel.Text = "Room: " .. currentRoom
    
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local humanoid = player.Character:FindFirstChild("Humanoid")
        
        if humanoid then
            speedLabel.Text = "Speed: " .. math.floor(humanoid.WalkSpeed)
        end
        
        local fps = math.floor(1 / RunService.RenderStepped:Wait())
        fpsLabel.Text = "FPS: " .. fps
        
        local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        pingLabel.Text = "Ping: " .. ping .. "ms"
        
        local pos = hrp.Position
        posLabel.Text = "Position: " .. math.floor(pos.X) .. ", " .. math.floor(pos.Y) .. ", " .. math.floor(pos.Z)
        
        local lookVector = hrp.CFrame.LookVector
        local direction = "North"
        if math.abs(lookVector.X) > math.abs(lookVector.Z) then
            direction = lookVector.X > 0 and "East" or "West"
        else
            direction = lookVector.Z > 0 and "South" or "North"
        end
        lookLabel.Text = "Looking: " .. direction
    end
end

