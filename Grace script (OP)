    local toggle = Instance.new("Frame", parent)
    toggle.BackgroundTransparency = 1
    toggle.Position = position
    toggle.Size = UDim2.new(0, 350, 0, 25)
    
    local label = Instance.new("TextLabel", toggle)
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(1, -100, 1, 0)
    label.Font = Enum.Font.Code
    label.Text = text
    label.TextColor3 = THEME.text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local bindBtn = Instance.new("TextButton", toggle)
    bindBtn.BackgroundColor3 = THEME.button
    bindBtn.BorderSizePixel = 0
    bindBtn.Position = UDim2.new(1, -90, 0, 3)
    bindBtn.Size = UDim2.new(0, 55, 0, 19)
    bindBtn.Font = Enum.Font.Code
    bindBtn.Text = "..."
    bindBtn.TextColor3 = THEME.text
    bindBtn.TextSize = 10
    
    local bindCorner = Instance.new("UICorner", bindBtn)
    bindCorner.CornerRadius = UDim.new(0, 4)
    
    local bindOutline = Instance.new("UIStroke", bindBtn)
    bindOutline.Color = THEME.outline
    bindOutline.Thickness = 1
    
    local toggleBtn = Instance.new("TextButton", toggle)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Position = UDim2.new(1, -30, 0, 3)
    toggleBtn.Size = UDim2.new(0, 25, 0, 19)
    toggleBtn.AutoButtonColor = false
    toggleBtn.Text = ""
    
    local toggleCorner = Instance.new("UICorner", toggleBtn)
    toggleCorner.CornerRadius = UDim.new(0, 10)
    
    local toggleOutline = Instance.new("UIStroke", toggleBtn)
    toggleOutline.Color = THEME.outline
    toggleOutline.Thickness = 1
    
    local toggleDot = Instance.new("Frame", toggleBtn)
    toggleDot.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    toggleDot.BorderSizePixel = 0
    toggleDot.Position = UDim2.new(0, 2, 0, 2)
    toggleDot.Size = UDim2.new(0, 15, 0, 15)
    
    local dotCorner = Instance.new("UICorner", toggleDot)
    dotCorner.CornerRadius = UDim.new(1, 0)
    
    local isOn = false
    local currentKey = nil
    
    local function toggleState()
        isOn = not isOn
        
        if isOn then
            TweenService:Create(toggleBtn, TweenInfo.new(0.2), {
                BackgroundColor3 = THEME.main
            }):Play()
            TweenService:Create(toggleDot, TweenInfo.new(0.2), {
                Position = UDim2.new(0, 8, 0, 2),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            }):Play()
        else
            TweenService:Create(toggleBtn, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            }):Play()
            TweenService:Create(toggleDot, TweenInfo.new(0.2), {
                Position = UDim2.new(0, 2, 0, 2),
                BackgroundColor3 = Color3.fromRGB(200, 200, 200)
            }):Play()
        end
        
        showNotification(text .. " " .. (isOn and "enabled" or "disabled"))
        
        if callback then
            callback(isOn)
        end
    end
    
    toggleBtn.MouseButton1Click:Connect(toggleState)
    
    -- Store toggle function for keybinds
    toggleFunctions[text:lower():gsub(" ", "")] = toggleState
    
    -- Bind button functionality - FIXED based on reference
    bindBtn.MouseButton1Click:Connect(function()
        bindingMode = true
        bindingOption = text
        bindingCallback = function(newKey)
            if newKey == Enum.KeyCode.G then
                showNotification("Cannot bind to G key (reserved)")
                return false
            end
            
            if usedKeybinds[newKey] then
                showNotification("Key already in use")
                return false
            end
            
            -- Remove old keybind
            if currentKey then
                usedKeybinds[currentKey] = nil
                keybinds[text:lower():gsub(" ", "")] = nil
            end
            
            -- Set new keybind
            usedKeybinds[newKey] = true
            currentKey = newKey
            bindBtn.Text = getKeyName(newKey)
            keybinds[text:lower():gsub(" ", "")] = newKey
            
            return true
        end
        KeybindDisplay.Visible = true
        keybindTitle.Text = "Press any key to bind " .. text .. "..."
    end)
    
    return toggle, function() return isOn end, toggleState
end

local function createSlider(parent, text, position, min, max, default, callback)
    local slider = Instance.new("Frame", parent)
    slider.BackgroundTransparency = 1
    slider.Position = position
    slider.Size = UDim2.new(0, 200, 0, 40)
    
    local label = Instance.new("TextLabel", slider)
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 0, 0, 0)
    label.Size = UDim2.new(1, 0, 0.5, 0)
    label.Font = Enum.Font.Code
    label.Text = text .. ": " .. math.floor(default * 10) / 10
    label.TextColor3 = THEME.text
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local track = Instance.new("Frame", slider)
    track.BackgroundColor3 = THEME.button
    track.BorderSizePixel = 0
    track.Position = UDim2.new(0, 0, 0.5, 5)
    track.Size = UDim2.new(1, 0, 0, 4)
    
    local trackCorner = Instance.new("UICorner", track)
    trackCorner.CornerRadius = UDim.new(1, 0)
    
    local trackOutline = Instance.new("UIStroke", track)
    trackOutline.Color = THEME.outline
    trackOutline.Thickness = 1
    
    local fill = Instance.new("Frame", track)
    fill.BackgroundColor3 = THEME.main
    fill.BorderSizePixel = 0
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    
    local fillCorner = Instance.new("UICorner", fill)
    fillCorner.CornerRadius = UDim.new(1, 0)
    
    local handle = Instance.new("TextButton", track)
    handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    handle.BorderSizePixel = 0
    handle.Position = UDim2.new((default - min) / (max - min), -6, 0, -4)
    handle.Size = UDim2.new(0, 12, 0, 12)
    handle.Text = ""
    
    local handleCorner = Instance.new("UICorner", handle)
    handleCorner.CornerRadius = UDim.new(1, 0)
    
    local handleOutline = Instance.new("UIStroke", handle)
    handleOutline.Color = THEME.outline
    handleOutline.Thickness = 1
    
    local dragging = false
    local value = default
    
    handle.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mouse = player:GetMouse()
            local relativeX = math.clamp((mouse.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            value = min + (max - min) * relativeX
            
            handle.Position = UDim2.new(relativeX, -6, 0, -4)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = text .. ": " .. math.floor(value * 10) / 10
            
            if callback then
                callback(value)
            end
        end
    end)
    
    local sliderObject = {
        slider = slider,
        updateValue = function(newValue)
            value = newValue
            local relativeX = (newValue - min) / (max - min)
            handle.Position = UDim2.new(relativeX, -6, 0, -4)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            label.Text = text .. ": " .. math.floor(newValue * 10) / 10
        end,
        getValue = function()
            return value
        end
    }
    
    return sliderObject
end

local function createTextBox(parent, placeholder, position, size, callback)
    local frame = Instance.new("Frame", parent)
