local function makeInvisible()
    local char = LocalPlayer.Character
    if not char then return end
    
    savedCharacterData = {}
    State.InvisibleActive = true
    
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("Decal") or part:IsA("Texture") then
            table.insert(savedCharacterData, {part = part, transparency = part.Transparency})
            part.Transparency = 1
        end
    end
    
    pcall(function()
        for _, acc in ipairs(char:GetChildren()) do
            if acc:IsA("Accessory") then
                local h = acc:FindFirstChild("Handle")
                if h then
                    table.insert(savedCharacterData, {part = h, transparency = h.Transparency})
                    h.Transparency = 1
                end
            end
        end
    end)
    
    updateStatus("👻 Invisible ACTIVATED", C.Purple)
end

local function makeVisible()
    State.InvisibleActive = false
    for _, d in ipairs(savedCharacterData) do
        if d.part and d.part.Parent then
            d.part.Transparency = d.transparency
        end
    end
    savedCharacterData = {}
    updateStatus("👤 Visible restored", C.Green)
end

