local function startFarmCheese()
    State.FarmCheeseActive = true
    updateStatus("🧀 Auto Farm STARTED", C.Green)
    
    spawn(function()
        while State.FarmCheeseActive and State.ScriptActive do
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = CFrame.new(CHEESE_POS)
                    task.wait(0.8)
                    
                    for _, obj in ipairs(workspace:GetDescendants()) do
                        if not State.FarmCheeseActive then break end
                        if obj.Name:lower():find("cheese") and obj:IsA("BasePart") then
                            if (obj.Position - CHEESE_POS).Magnitude < 120 then
                                hrp.CFrame = CFrame.new(obj.Position)
                                task.wait(0.25)
                            end
                        end
                    end
                    
                    if State.FarmCheeseActive and char.Parent then
                        local hrp2 = char:FindFirstChild("HumanoidRootPart")
                        if hrp2 then hrp2.CFrame = CFrame.new(CHEESE_POS) end
                    end
                end
            end
            task.wait(1.5)
        end
    end)
end

