local function switchTab(tabName)
    State.CurrentTab = tabName
    
    for name, frame in pairs(tabFrames) do
        if name == tabName then
            frame.Visible = true
            tweenProperty(frame, {BackgroundTransparency = frame.BackgroundTransparency}, 0.2)
        else
            frame.Visible = false
        end
    end
    
    for name, btn in pairs(tabButtons) do
        if name == tabName then
            tweenProperty(btn, {BackgroundColor3 = C.Gold, BackgroundTransparency = 0.15}, 0.25)
            local tl = btn:FindFirstChild("TabLabel")
            if tl then tweenProperty(tl, {TextColor3 = C.TextWhite}, 0.25) end
        else
            tweenProperty(btn, {BackgroundColor3 = C.BgCard, BackgroundTransparency = 0.6}, 0.25)
            local tl = btn:FindFirstChild("TabLabel")
            if tl then tweenProperty(tl, {TextColor3 = C.TextMuted}, 0.25) end
        end
    end
end

