                particle.ZIndex = 1
                particle.Parent = MainFrame
                Instance.new("UICorner", particle).CornerRadius = UDim.new(1, 0)
                
                local targetX = particle.Position.X.Scale + (math.random() - 0.5) * 0.2
                
                tweenProperty(particle, {
                    Position = UDim2.new(targetX, 0, -0.05, 0),
