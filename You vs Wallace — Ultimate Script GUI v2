local function getPlayerInFOV()
    local cam = workspace.CurrentCamera
    local viewportSize = cam.ViewportSize
    local centerScreen = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)

    local closestPlayer = nil
    local closestScreenDist = Patch22.AimbotFOVRadius

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            local hum = player.Character:FindFirstChildOfClass("Humanoid")

            if head and hum and hum.Health > 0 then
                local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)

                if onScreen then
                    local screenPoint = Vector2.new(screenPos.X, screenPos.Y)
                    local distFromCenter = (screenPoint - centerScreen).Magnitude

                    if distFromCenter < closestScreenDist then
                        closestScreenDist = distFromCenter
                        closestPlayer = player
                    end
                end
            end
        end
    end

    return closestPlayer
end

local aimbotV2Connection = nil
local aimbotRMBHeld = false

local function enableAimbotV2()
    Patch22.AimbotV2Enabled = true
    AimbotCircle.Visible = true

    -- Пульсация круга
    spawn(function()
        while Patch22.AimbotV2Enabled do
            tweenProperty(outerStroke, {Transparency = 0.6}, 1, Enum.EasingStyle.Sine)
            task.wait(1)
            tweenProperty(outerStroke, {Transparency = 0.15}, 1, Enum.EasingStyle.Sine)
            task.wait(1)
        end
    end)

    aimbotV2Connection = RunService.RenderStepped:Connect(function()
        if not Patch22.AimbotV2Enabled then return end

        local targetInFOV = getPlayerInFOV()

        if targetInFOV then
            local isW = isWallacePlayer(targetInFOV)
            aimTargetLbl.Text = (isW and "💀 " or "👤 ") .. targetInFOV.Name
            aimTargetLbl.TextColor3 = isW and C.Red or C.TextLight
            outerStroke.Color = isW and C.Red or Color3.fromRGB(255, 165, 0)

            -- Если ПКМ зажата — наводить
            if aimbotRMBHeld and targetInFOV.Character then
                local head = targetInFOV.Character:FindFirstChild("Head")
                if head then
                    local cam = workspace.CurrentCamera
                    local smoothness = 0.15
                    local targetCF = CFrame.new(cam.CFrame.Position, head.Position)
                    cam.CFrame = cam.CFrame:Lerp(targetCF, smoothness)

                    aimStatusLbl.Text = "🔒 LOCKED"
                    aimStatusLbl.TextColor3 = C.Green
                    outerStroke.Thickness = 3

                    centerDot.BackgroundColor3 = C.Green
                    centerDot.Size = UDim2.new(0, 10, 0, 10)
                    centerDot.Position = UDim2.new(0.5, -5, 0.5, -5)
                end
            else
                aimStatusLbl.Text = "🎯 AIMBOT"
                aimStatusLbl.TextColor3 = C.Red
                outerStroke.Thickness = 2

                centerDot.BackgroundColor3 = C.Red
                centerDot.Size = UDim2.new(0, 6, 0, 6)
                centerDot.Position = UDim2.new(0.5, -3, 0.5, -3)
            end
        else
            aimTargetLbl.Text = "No target in FOV"
            aimTargetLbl.TextColor3 = C.TextDark
            aimStatusLbl.Text = "🎯 AIMBOT"
            aimStatusLbl.TextColor3 = C.TextMuted
        end
    end)

    updateStatus("🎯 Aimbot V2 ENABLED — RMB to lock", C.Red)
end

local function disableAimbotV2()
    Patch22.AimbotV2Enabled = false
    AimbotCircle.Visible = false

    if aimbotV2Connection then
        aimbotV2Connection:Disconnect()
        aimbotV2Connection = nil
    end

    updateStatus("🎯 Aimbot V2 DISABLED", C.TextMuted)
end

