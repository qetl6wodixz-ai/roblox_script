local _origSwitchTab = switchTab

switchTab = function(tabName)
    -- Звук при переключении
    pcall(function()
        local tabSound = Instance.new("Sound")
        tabSound.SoundId = "rbxassetid://9125402735"
        tabSound.Volume = 0.3
        tabSound.PlaybackSpeed = 1.5
        tabSound.Parent = game:GetService("SoundService")
        tabSound:Play()
        task.delay(1, function() tabSound:Destroy() end)
    end)
    
    -- Анимация смены вкладки
    local currentFrame = tabFrames[State.CurrentTab]
    local newFrame = tabFrames[tabName]
    
    if currentFrame and currentFrame ~= newFrame then
        -- Fade out текущей
        for _, child in ipairs(currentFrame:GetChildren()) do
            if child:IsA("Frame") then
                tweenProperty(child, {BackgroundTransparency = 1}, 0.15)
            end
        end
    end
    
    -- Вызов оригинала
    _origSwitchTab(tabName)
    
    -- Fade in новой
    if newFrame then
        for _, child in ipairs(newFrame:GetChildren()) do
            if child:IsA("Frame") and child.BackgroundTransparency < 1 then
                local origTransparency = child.BackgroundTransparency
                child.BackgroundTransparency = 1
                tweenProperty(child, {BackgroundTransparency = origTransparency}, 0.3)
            end
        end
    end
end

