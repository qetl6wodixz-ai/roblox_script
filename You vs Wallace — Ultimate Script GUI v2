                hpLbl.TextColor3 = C.Orange
            else
                hpFill.BackgroundColor3 = C.Green
                hpLbl.TextColor3 = C.Green
            end
        end
    end)
    
    data.updateConn = updateConn
    espObjects[player] = data
end

local function enableESP()
    State.ESPEnabled = true
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if player.Character then createESPForPlayer(player) end
            local conn = player.CharacterAdded:Connect(function()
                task.wait(1)
                if State.ESPEnabled then createESPForPlayer(player) end
            end)
            table.insert(espConnections, conn)
        end
    end
    
    local joinConn = Players.PlayerAdded:Connect(function(player)
        if not State.ESPEnabled then return end
        player.CharacterAdded:Connect(function()
            task.wait(1)
            if State.ESPEnabled then createESPForPlayer(player) end
        end)
    end)
    table.insert(espConnections, joinConn)
    
    local leaveConn = Players.PlayerRemoving:Connect(function(player)
        removeESP(player)
    end)
    table.insert(espConnections, leaveConn)
    
    updateStatus("👁 ESP Active — tracking all players", C.Green)
end

local function disableESP()
    State.ESPEnabled = false
    for p, _ in pairs(espObjects) do removeESP(p) end
    for _, conn in ipairs(espConnections) do
        pcall(function() conn:Disconnect() end)
    end
    espConnections = {}
    updateStatus("👁 ESP Disabled", C.TextMuted)
end

