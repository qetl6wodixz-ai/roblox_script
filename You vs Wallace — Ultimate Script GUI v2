local function teleportTo(pos)
    local char = LocalPlayer.Character
    if not char then
        updateStatus("⚠ No character!", C.Red)
        return false
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        updateStatus("⚠ No HumanoidRootPart!", C.Red)
        return false
    end
    hrp.CFrame = CFrame.new(pos)
    return true
end

local function teleportToPlayer(player)
    if not player or not player.Character then
        updateStatus("⚠ Player not found!", C.Red)
        return
    end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        updateStatus("⚠ Player has no HRP!", C.Red)
        return
    end
    if teleportTo(hrp.Position + Vector3.new(0, 3, 0)) then
        updateStatus("📍 Teleported to " .. player.Name, C.Green)
    end
end

