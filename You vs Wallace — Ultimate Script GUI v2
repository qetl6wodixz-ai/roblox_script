local function getAllEggs()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local eggs = {}
    local function search(parent)
        for _, obj in ipairs(parent:GetChildren()) do
            if obj.Name:lower():find("egg") then
                if obj:IsA("BasePart") then
                    table.insert(eggs, obj)
                elseif obj:IsA("Model") then
                    local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                    if part then table.insert(eggs, part) end
                end
            end
            if #obj:GetChildren() > 0 then search(obj) end
        end
    end
    search(workspace)
    
    if #eggs == 0 then
        updateStatus("🥚 No eggs found!", C.Orange)
        return
    end
    
    updateStatus("🥚 Found " .. #eggs .. " eggs!", C.Green)
    
    spawn(function()
        for i, egg in ipairs(eggs) do
            if not State.ScriptActive then break end
            if egg and egg.Parent then
                hrp.CFrame = CFrame.new(egg.Position + Vector3.new(0, 3, 0))
                updateStatus("🥚 Egg " .. i .. "/" .. #eggs, C.Orange)
                task.wait(0.4)
            end
        end
        updateStatus("🥚 All " .. #eggs .. " eggs collected!", C.Green)
    end)
end

