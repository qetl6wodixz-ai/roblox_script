    tabBtn.LayoutOrder = def.Order
    tabBtn.ZIndex = 4
    tabBtn.Parent = TabBar
    Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 6)
    
    local tabLabel = Instance.new("TextLabel")
    tabLabel.Name = "TabLabel"
    tabLabel.Size = UDim2.new(1, 0, 1, 0)
    tabLabel.BackgroundTransparency = 1
    tabLabel.Text = def.Icon .. " " .. def.Name
    tabLabel.TextColor3 = C.TextMuted
    tabLabel.TextSize = 11
    tabLabel.Font = Enum.Font.GothamBold
    tabLabel.ZIndex = 5
    tabLabel.Parent = tabBtn
    
    tabBtn.MouseEnter:Connect(function()
        if State.CurrentTab ~= def.Name then
            tweenProperty(tabBtn, {BackgroundTransparency = 0.3}, 0.2)
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if State.CurrentTab ~= def.Name then
            tweenProperty(tabBtn, {BackgroundTransparency = 0.6}, 0.2)
        end
    end)
    
    tabBtn.MouseButton1Click:Connect(function()
        switchTab(def.Name)
    end)
    
    tabButtons[def.Name] = tabBtn
    
    -- Создание контейнера для вкладки
    local tabContent = Instance.new("ScrollingFrame")
