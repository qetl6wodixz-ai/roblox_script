            if currentHum.MaxHealth >= 1000 and not isWallace then
                -- Пересоздаём ESP для нового Wallace
                task.defer(function()
                    if State.ESPEnabled then
                        createESPForPlayer(player)
                    end
                end)
            end
        end
    end)

