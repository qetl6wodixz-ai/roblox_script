local function getClosestPlayer()
    local closest = nil
    local closestDist = math.huge
    local localChar = LocalPlayer.Character
    if not localChar then return nil end
    local localHRP = localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return nil end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (hrp.Position - localHRP.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = player
                end
            end
        end
    end
    
    -- Также проверяем NPC Wallace
    local function checkWallaceNPC(parent)
        for _, obj in ipairs(parent:GetChildren()) do
            if obj.Name:lower():find("wallace") and obj:IsA("Model") then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or
                            obj:FindFirstChild("Head") or
                            obj:FindFirstChildWhichIsA("BasePart")
                if hrp then
                    local dist = (hrp.Position - localHRP.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = {Character = obj, Name = "WALLACE"}
                    end
                end
            end
        end
    end
    checkWallaceNPC(workspace)
    
    return closest
end

local aimbotConnection = nil

local function enableAimbot()
    Addon.AimbotEnabled = true
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not Addon.AimbotEnabled then return end
        
        local target = getClosestPlayer()
        if not target then return end
        
        local targetChar = target.Character or target
        if not targetChar then return end
        
        local targetHead = targetChar:FindFirstChild("Head") or
                          targetChar:FindFirstChild("HumanoidRootPart") or
                          targetChar:FindFirstChildWhichIsA("BasePart")
        
        if not targetHead then return end
        
        local cam = workspace.CurrentCamera
        if cam then
            local targetPos = targetHead.Position
            cam.CFrame = CFrame.new(cam.CFrame.Position, targetPos)
        end
    end)
    
    updateStatus("🎯 Aimbot ENABLED — auto-tracking", C.Red)
end

local function disableAimbot()
    Addon.AimbotEnabled = false
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    updateStatus("🎯 Aimbot DISABLED", C.TextMuted)
end

