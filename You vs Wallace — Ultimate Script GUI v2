local function enableEggESPV2()
    Patch22.EggESPV2Enabled = true
    clearEggESPV2()

    local eggCount = 0

    local function scanWorkspaceForEggs(parent, depth)
        if depth > 15 then return end

        for _, obj in ipairs(parent:GetChildren()) do
            if not Patch22.EggESPV2Enabled then return end

            local objNameLower = obj.Name:lower()

            if objNameLower:find("egg") then
                local targetPart = nil
                local displayName = obj.Name

                if obj:IsA("BasePart") then
                    targetPart = obj
                elseif obj:IsA("Model") then
                    targetPart = obj.PrimaryPart
                        or obj:FindFirstChild("Handle")
                        or obj:FindFirstChild("Main")
                        or obj:FindFirstChild("Part")
                        or obj:FindFirstChildWhichIsA("MeshPart")
                        or obj:FindFirstChildWhichIsA("BasePart")
                end

                if targetPart then
                    eggCount = eggCount + 1
                    createEggESPV2Billboard(targetPart, displayName)
                end
            end

            if #obj:GetChildren() > 0 and not obj:IsA("PlayerGui") and not obj:IsA("Backpack") then
                scanWorkspaceForEggs(obj, depth + 1)
            end
        end
    end

    scanWorkspaceForEggs(workspace, 0)

    updateStatus("🥚 Egg ESP V2: Found " .. eggCount .. " eggs in Workspace", Color3.fromRGB(255, 220, 50))

    -- Авто-обновление каждые 4 секунды
    spawn(function()
        while Patch22.EggESPV2Enabled and State.ScriptActive do
            task.wait(4)
            if Patch22.EggESPV2Enabled then
                clearEggESPV2()
                eggCount = 0
                scanWorkspaceForEggs(workspace, 0)
            end
        end
    end)
end

