local function createSoundRow(index, sound)
    local soundId = tostring(sound.SoundId)
    local soundName = sound.Name

    local row = Instance.new("Frame")
    row.Name = "Sound_" .. index
    row.Size = UDim2.new(1, -5, 0, 40)
    row.BackgroundColor3 = index % 2 == 0 
        and Color3.fromRGB(35, 35, 48) 
        or Color3.fromRGB(30, 30, 42)
    row.BorderSizePixel = 0
    row.Parent = scrollFrame
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

    -- Номер
    local numLabel = Instance.new("TextLabel")
    numLabel.Size = UDim2.new(0, 30, 1, 0)
    numLabel.Position = UDim2.new(0, 5, 0, 0)
    numLabel.BackgroundTransparency = 1
    numLabel.Text = tostring(index)
    numLabel.TextColor3 = Color3.fromRGB(100, 100, 130)
    numLabel.TextSize = 12
    numLabel.Font = Enum.Font.GothamBold
    numLabel.TextXAlignment = Enum.TextXAlignment.Left
    numLabel.Parent = row

    -- Имя звука
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0, 150, 1, 0)
    nameLabel.Position = UDim2.new(0, 35, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = soundName
    nameLabel.TextColor3 = Color3.fromRGB(100, 220, 255)
    nameLabel.TextSize = 12
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.Parent = row

    -- Sound ID
    local idLabel = Instance.new("TextLabel")
    idLabel.Size = UDim2.new(0, 190, 1, 0)
    idLabel.Position = UDim2.new(0, 190, 0, 0)
    idLabel.BackgroundTransparency = 1
    idLabel.Text = soundId
    idLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    idLabel.TextSize = 11
    idLabel.Font = Enum.Font.Gotham
    idLabel.TextXAlignment = Enum.TextXAlignment.Left
    idLabel.TextTruncate = Enum.TextTruncate.AtEnd
    idLabel.Parent = row

    -- Кнопка PLAY ▶
    local playBtn = Instance.new("TextButton")
    playBtn.Size = UDim2.new(0, 30, 0, 26)
    playBtn.Position = UDim2.new(0, 385, 0, 7)
    playBtn.BackgroundColor3 = Color3.fromRGB(50, 170, 50)
    playBtn.Text = "▶"
    playBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    playBtn.TextSize = 14
    playBtn.Font = Enum.Font.GothamBold
    playBtn.BorderSizePixel = 0
    playBtn.Parent = row
    Instance.new("UICorner", playBtn).CornerRadius = UDim.new(0, 5)

    playBtn.MouseButton1Click:Connect(function()
        sound:Play()
        playBtn.BackgroundColor3 = Color3.fromRGB(30, 130, 30)
        wait(0.3)
        playBtn.BackgroundColor3 = Color3.fromRGB(50, 170, 50)
    end)

    -- Кнопка STOP ⏹
    local stopBtn = Instance.new("TextButton")
    stopBtn.Size = UDim2.new(0, 30, 0, 26)
    stopBtn.Position = UDim2.new(0, 420, 0, 7)
    stopBtn.BackgroundColor3 = Color3.fromRGB(200, 55, 55)
    stopBtn.Text = "⏹"
    stopBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    stopBtn.TextSize = 14
    stopBtn.Font = Enum.Font.GothamBold
    stopBtn.BorderSizePixel = 0
    stopBtn.Parent = row
    Instance.new("UICorner", stopBtn).CornerRadius = UDim.new(0, 5)

    stopBtn.MouseButton1Click:Connect(function()
        sound:Stop()
    end)

    -- Кнопка COPY 📋
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 60, 0, 26)
    copyBtn.Position = UDim2.new(0, 455, 0, 7)
    copyBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 170)
    copyBtn.Text = "📋 Copy"
    copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    copyBtn.TextSize = 11
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.BorderSizePixel = 0
    copyBtn.Parent = row
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 5)

    copyBtn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(soundId)
        elseif toclipboard then
            toclipboard(soundId)
        end
        copyBtn.Text = "✅"
        copyBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        wait(1)
        copyBtn.Text = "📋 Copy"
        copyBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 170)
    end)

    return row
end

