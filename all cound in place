-- СКАНИРОВАНИЕ ЗВУКОВ
----------------------------------------------------------------
local allSounds = {}
local allRows = {}

local function scanSounds()
    allSounds = {}

    local locations = {
        game.Workspace,
        game.SoundService,
        game.Lighting,
        game.ReplicatedStorage,
        game.StarterGui,
        game.StarterPack,
        game.StarterPlayer,
    }

    -- Пробуем добавить ReplicatedFirst
    pcall(function()
        table.insert(locations, game.ReplicatedFirst)
    end)

    for _, location in ipairs(locations) do
        pcall(function()
            for _, obj in ipairs(location:GetDescendants()) do
                if obj:IsA("Sound") then
                    table.insert(allSounds, obj)
                end
            end
        end)
    end
end

local function renderSounds(filter)
    -- Очищаем старые строки
    for _, row in ipairs(allRows) do
        if row and row.Parent then
            row:Destroy()
        end
    end
    allRows = {}

    local count = 0
    for i, sound in ipairs(allSounds) do
        local soundName = sound.Name:lower()
        local soundId = tostring(sound.SoundId):lower()
        local query = (filter or ""):lower()

        if query == "" or soundName:find(query, 1, true) or soundId:find(query, 1, true) then
            count = count + 1
            local row = createSoundRow(count, sound)
            table.insert(allRows, row)
        end
    end

    -- Обновляем CanvasSize
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, count * 43 + 10)

    -- Обновляем заголовок
    titleLabel.Text = "🔊 Sound Finder — Найдено: " .. count
end

----------------------------------------------------------------
-- ЗАПУСК
----------------------------------------------------------------
scanSounds()
renderSounds("")

