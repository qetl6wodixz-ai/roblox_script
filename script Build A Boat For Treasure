            if keys[Enum.KeyCode.D] then dir = dir + cf.RightVector end
            if keys[Enum.KeyCode.Space] then dir = dir + Vector3.new(0, 1, 0) end
            if keys[Enum.KeyCode.LeftControl] or keys[Enum.KeyCode.LeftShift] then dir = dir - Vector3.new(0, 1, 0) end
            bv.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.zero
            bg.CFrame = cf
        end)
    else
