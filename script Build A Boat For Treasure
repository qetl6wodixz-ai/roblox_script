    iconLabel.Text = icon or "◆"
    iconLabel.TextSize = 16
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.TextColor3 = Theme.TextPrimary
    iconLabel.Parent = frame

    -- Текст
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -120, 1, 0)
    label.Position = UDim2.new(0, 42, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextSize = 13
    label.Font = Enum.Font.GothamSemibold
    label.TextColor3 = Theme.TextPrimary
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    -- Toggle switch
    local toggleBg = Instance.new("TextButton")
    toggleBg.Size = UDim2.new(0, 44, 0, 22)
    toggleBg.Position = UDim2.new(1, -56, 0.5, -11)
    toggleBg.BackgroundColor3 = Theme.Toggle_Off
    toggleBg.Text = ""
    toggleBg.BorderSizePixel = 0
    toggleBg.AutoButtonColor = false
    toggleBg.Parent = frame

    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(1, 0)
    toggleCorner.Parent = toggleBg

    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 18, 0, 18)
    circle.Position = UDim2.new(0, 2, 0.5, -9)
    circle.BackgroundColor3 = Theme.TextPrimary
    circle.BorderSizePixel = 0
    circle.Parent = toggleBg

    local circleCorner = Instance.new("UICorner")
    circleCorner.CornerRadius = UDim.new(1, 0)
    circleCorner.Parent = circle

    -- Статус текст
    local statusText = Instance.new("TextLabel")
    statusText.Size = UDim2.new(0, 35, 0, 14)
    statusText.Position = UDim2.new(1, -58, 0, 1)
    statusText.BackgroundTransparency = 1
    statusText.Text = "OFF"
    statusText.TextSize = 9
    statusText.Font = Enum.Font.GothamBold
    statusText.TextColor3 = Theme.TextMuted
    statusText.Visible = false
    statusText.Parent = frame

    local function updateToggle(state)
        if state then
            TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Toggle_On}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Position = UDim2.new(0, 24, 0.5, -9)}):Play()
        else
            TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Toggle_Off}):Play()
            TweenService:Create(circle, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Position = UDim2.new(0, 2, 0.5, -9)}):Play()
        end
    end

    toggleBg.MouseButton1Click:Connect(function()
        States[stateKey] = not States[stateKey]
        updateToggle(States[stateKey])
        if callback then callback(States[stateKey]) end
    end)

    -- Hover
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            TweenService:Create(frame, TweenInfo.new(0.15), {BackgroundColor3 = Theme.CardHover}):Play()
        end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            TweenService:Create(frame, TweenInfo.new(0.15), {BackgroundColor3 = Theme.Card}):Play()
        end
    end)

    return frame, updateToggle
end

